@model IEnumerable<Themes.Models.Note>

@{
    ViewData["Title"] = "My Notes";
}

<div class="py-8">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">My Notes</h1>
            <p class="mt-2 text-slate-600">Browse through all your documented thoughts.</p>
        </div>
        <a asp-action="Create" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all transform hover:scale-105 active:scale-95">
            <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
            </svg>
            Add New Note
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-12 px-4 border-2 border-dashed border-slate-300 rounded-lg">
            <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            <h3 class="mt-2 text-sm font-medium text-slate-900">No notes found</h3>
            <p class="mt-1 text-sm text-slate-500">Create a note within one of your lists.</p>
        </div>
    }
    else
    {
        <div class="bg-white shadow-sm border border-slate-200 rounded-xl overflow-hidden">
            <ul role="list" class="divide-y divide-slate-100">
                @foreach (var item in Model)
                {
                    <li class="group hover:bg-slate-50 transition-colors duration-150">
                        <div class="px-6 py-5 flex items-center">
                            <div class="min-w-0 flex-1 pr-4">
                                <div class="flex items-center space-x-3">
                                    <h4 class="text-lg font-bold text-slate-900 truncate group-hover:text-indigo-600 transition-colors">@item.Title</h4>
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                                        @item.NoteList.Name
                                    </span>
                                </div>
                                <div class="mt-1">
                                    <p class="text-sm text-slate-600 line-clamp-1">@item.Description</p>
                                </div>
                                <div class="mt-2 flex items-center text-xs text-slate-400">
                                    <svg class="flex-shrink-0 mr-1.5 h-4 w-4 text-slate-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                                    </svg>
                                    <time datetime="@item.Date.ToString("yyyy-MM-dd")">@item.Date.ToString("MMM dd, yyyy")</time>
                                </div>
                            </div>
                            <div class="flex items-center space-x-3 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="p-2 text-slate-400 hover:text-indigo-600 rounded-lg hover:bg-white hover:shadow-sm" title="Edit">
                                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="p-2 text-slate-400 hover:text-indigo-600 rounded-lg hover:bg-white hover:shadow-sm" title="Details">
                                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="p-2 text-slate-400 hover:text-red-600 rounded-lg hover:bg-white hover:shadow-sm" title="Delete">
                                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                </a>
                            </div>
                        </div>
                    </li>
                }
            </ul>
        </div>
    }
</div>
